# Backend
APP_NAME="AI SRE Agent"
APP_ENV=development
DATABASE_URL=sqlite:///./ai_sre_agent.db

# LLM
LLM_PROVIDER=mock
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
QWEN_API_KEY=
MODEL_NAME=
# 首版只允许模拟处置；真实环境不能设置为可执行模式。
AGENT_EXECUTION_MODE=simulation
LLM_TIMEOUT_SECONDS=60
AGENT_MAX_STEPS=12

# Local development frontend origins
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Frontend
VITE_API_BASE_URL=http://localhost:8000
